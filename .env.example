# Stormwind Test Credentials Template
# Copy this file to .env and fill in your credentials

# Admin user credentials
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD=your-admin-password

# Manager user credentials
MANAGER_EMAIL=your-manager-email@example.com
MANAGER_PASSWORD=your-manager-password

# Student user credentials
STUDENT_EMAIL=your-student-email@example.com
STUDENT_PASSWORD=your-student-password

# Base URL (optional)
BASE_URL=https://test-spectre.pantheonsite.io/
